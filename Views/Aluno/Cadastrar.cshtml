@model Atividade.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<div class="container mt-4">
    <h2>Formulário de Cadastro de Aluno</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Cadastrar" method="post">

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome Completo</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RA" class="form-label">RA (Registro Acadêmico)</label>
                    <input asp-for="RA" class="form-control" />
                    <span asp-validation-for="RA" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Curso" class="form-label">Curso</label>
                    <input asp-for="Curso" class="form-control" />
                    <span asp-validation-for="Curso" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DataNascimento" class="form-label">Data de Nascimento</label>
                    <input asp-for="DataNascimento" class="form-control" type="date" />
                    <span asp-validation-for="DataNascimento" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Cadastrar Aluno</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}