@model Atividade.Models.Aluno

@{
    ViewData["Title"] = "Confirmação de Cadastro";
}

<div class="container mt-4">
    <div class="alert alert-success d-flex align-items-center" role="alert">
        <svg class="bi flex-shrink-0 me-2" width="24" height="24" role="img" aria-label="Success:" viewBox="0 0 16 16" fill="currentColor" style="margin-right: 10px;">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
        </svg>
        <div>
            <strong>Sucesso!</strong> O aluno foi cadastrado no sistema com êxito.
        </div>
    </div>

    <div class="card mt-4 shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Dados do Aluno Cadastrado</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Nome Completo:</dt>
                <dd class="col-sm-9 font-weight-bold">@Model.Nome</dd>

                <dt class="col-sm-3 text-muted">E-mail:</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3 text-muted">RA:</dt>
                <dd class="col-sm-9"><code>@Model.RA</code></dd>

                <dt class="col-sm-3 text-muted">Curso:</dt>
                <dd class="col-sm-9">@Model.Curso</dd>

                <dt class="col-sm-3 text-muted">Data de Nascimento:</dt>
                <dd class="col-sm-9">@Model.DataNascimento.ToShortDateString()</dd>
            </dl>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Cadastrar" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Cadastrar outro aluno
        </a>
    </div>
</div>